<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ibmec_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:orientation="vertical"
            android:background="@color/ibmec_blue"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="52dp"
            android:paddingBottom="20dp"
            android:gravity="bottom">

            <TextView
                android:id="@+id/txtTituloHistoricoResumo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Resumo da Inspeção"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_aula"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:id="@+id/txtHistoricoContexto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TERCA • MANHÃ"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Taxa de faltas"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="24dp" />

                <TextView
                    android:id="@+id/txtHistoricoTaxaFaltas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0,00%"
                    android:textColor="@color/ibmec_blue"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/txtHistoricoMetricas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✓ Presentes: 0"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:lineSpacingExtra="7dp"
                    android:layout_marginTop="22dp" />

            </LinearLayout>

            <FrameLayout
                android:id="@+id/containerHistoricoFragment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp" />

            <Button
                android:id="@+id/btnCompartilharHistorico"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Compartilhar Relatório"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:backgroundTint="@color/ibmec_blue"
                android:layout_marginTop="28dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnVoltarHistorico"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Voltar para Histórico"
                android:textColor="@color/ibmec_blue"
                android:textStyle="bold"
                android:textSize="16sp"
                android:background="@drawable/second_button"
                android:layout_marginTop="16dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>