<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ibmec_background">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="@color/ibmec_blue"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="48dp"
        android:paddingBottom="22dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true"
            android:layout_alignParentBottom="true">

            <TextView
                android:id="@+id/txtBemVindo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Olá, Inspetor 1"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtTipoUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INSPETOR"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <ImageView
            android:id="@+id/imgLogoHome"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ibmec_icon"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true" />

    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ações disponíveis"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnRealizarInspecao"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Realizar Inspeção"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:backgroundTint="@color/ibmec_blue" />

        <Button
            android:id="@+id/btnHistorico"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Histórico de Inspeções"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:backgroundTint="@color/ibmec_blue"
            android:layout_marginTop="16dp"/>

    </LinearLayout>

</LinearLayout>