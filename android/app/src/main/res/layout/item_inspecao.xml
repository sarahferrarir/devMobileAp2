<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="18dp"
    android:layout_marginBottom="14dp"
    android:background="@drawable/card_aula">

    <TextView
        android:id="@+id/txtInspecaoTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Inspeção #1"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtInspecaoInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SEGUNDA • MANHÃ"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/txtInspecaoStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Finalizada"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp" />

</LinearLayout>