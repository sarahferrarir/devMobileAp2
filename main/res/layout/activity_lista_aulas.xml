<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ibmec_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:orientation="vertical"
        android:background="@color/ibmec_blue"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="52dp"
        android:paddingBottom="20dp"
        android:gravity="bottom">

        <TextView
            android:id="@+id/txtTituloLista"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SEGUNDA • TARDE"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtDataInspecao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2026-06-15"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:layout_marginTop="6dp" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAulas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="20dp"
        android:clipToPadding="false" />

    <Button
        android:id="@+id/btnFinalizarInspecao"
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:text="Finalizar Inspeção"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:backgroundTint="@color/ibmec_blue"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp" />

</LinearLayout>